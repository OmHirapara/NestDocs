    "/tours": {
      "get": {
        "operationId": "ToursController_findAll",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "object"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "Tours"
        ],
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "difficulty",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "minPrice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "maxPrice",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "security": []
      },
      "post": {
        "operationId": "ToursController_create",
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "tags": [
          "Tours"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string",
                    "minLength": 3,
                    "maxLength": 100,
                    "example": "Sample Name"
                  },
                  "description": {
                    "type": "string",
                    "minLength": 20,
                    "maxLength": 2000,
                    "example": "A detailed description of the resource."
                  },
                  "price": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 999999,
                    "example": 500000
                  },
                  "duration": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 365,
                    "example": 183
                  },
                  "category": {
                    "type": "string",
                    "enum": [
                      "adventure",
                      "cultural",
                      "wildlife",
                      "beach",
                      "mountain"
                    ],
                    "example": "adventure"
                  },
                  "difficulty": {
                    "type": "string",
                    "enum": [
                      "easy",
                      "moderate",
                      "hard"
                    ],
                    "example": "easy"
                  },
                  "maxGroupSize": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 50,
                    "example": 26
                  },
                  "highlights": {
                    "type": "string",
                    "example": "string"
                  },
                  "startLocation": {
                    "type": "string",
                    "example": "Downtown"
                  }
                },
                "required": [
                  "name",
                  "description",
                  "price",
                  "duration",
                  "category",
                  "difficulty",
                  "maxGroupSize"
                ],
                "example": {
                  "name": "Sample Name",
                  "description": "A detailed description of the resource.",
                  "price": 500000,
                  "duration": 183,
                  "category": "adventure",
                  "difficulty": "easy",
                  "maxGroupSize": 26,
                  "highlights": "string",
                  "startLocation": "Downtown"
                }
              }
            }
          }
        },
        "security": [
          {
            "BearerAuth": []
          }
        ]
      }
    },
