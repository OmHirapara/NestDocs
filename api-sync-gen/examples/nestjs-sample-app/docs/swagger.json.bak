  "paths": {
    "/auth/login": {
      "post": {
        "operationId": "AuthController_login",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        },
        "tags": [
          "Auth"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email",
                    "example": "user@example.com"
                  },
                  "password": {
                    "type": "string",
                    "minLength": 8,
                    "example": "P@ssw0rd123"
                  }
                },
                "required": [
                  "email",
                  "password"
                ],
                "example": {
                  "email": "user@example.com",
                  "password": "P@ssw0rd123"
                }
              }
            }
          }
        },
        "security": []
      }
    },
    "/auth/refresh": {
