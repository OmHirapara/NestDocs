{
  "name": "@company/postman-sync-gen",
  "version": "1.0.0",
  "description": "Auto-generate Postman Collections and push to Team Workspace",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@company/api-sync-core": "*",
    "ajv": "^8.17.0",
    "axios": "^1.7.0",
    "newman": "^6.1.0",
    "openapi-types": "^12.1.3",
    "postman-collection": "^4.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/newman": "^5.3.6",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "ts-jest": "^29.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
