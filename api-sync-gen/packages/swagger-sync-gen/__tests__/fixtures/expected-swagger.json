{
  "openapi": "3.0.0",
  "info": {
    "title": "API Documentation",
    "description": "",
    "version": "1.0.0"
  },
  "paths": {
    "/tours": {
      "get": {
        "operationId": "ToursController_findAll",
        "tags": ["Tours"],
        "parameters": [
          { "name": "page", "in": "query", "required": false, "schema": { "type": "string" } },
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        },
        "security": []
      },
      "post": {
        "operationId": "ToursController_create",
        "tags": ["Tours"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTourDto" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        },
        "security": [{ "BearerAuth": [] }]
      }
    },
    "/tours/{id}": {
      "get": {
        "operationId": "ToursController_findOne",
        "tags": ["Tours"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        },
        "security": []
      },
      "put": {
        "operationId": "ToursController_update",
        "tags": ["Tours"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTourDto" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "application/json": { "schema": { "type": "object" } } }
          }
        },
        "security": [{ "BearerAuth": [] }]
      },
      "delete": {
        "operationId": "ToursController_remove",
        "tags": ["Tours"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "204": { "description": "No Content" }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {
      "CreateTourDto": {
        "type": "object",
        "properties": {
          "name": { "type": "string", "minLength": 3, "maxLength": 100 },
          "price": { "type": "number", "minimum": 0, "maximum": 999999 },
          "duration": { "type": "number", "minimum": 1 },
          "category": { "type": "string", "enum": ["adventure", "cultural", "wildlife"] },
          "description": { "type": "string" },
          "email": { "type": "string", "format": "email" }
        },
        "required": ["name", "price", "duration", "category"]
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
