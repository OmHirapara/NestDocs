{
  "name": "@company/swagger-sync-gen",
  "version": "1.0.0",
  "description": "Auto-generate OpenAPI 3.0 specs from NestJS/TypeScript code",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^10.1.0",
    "@company/api-sync-core": "*",
    "chokidar": "^3.6.0",
    "express": "^4.19.0",
    "openapi-types": "^12.1.3",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/swagger-ui-express": "^4.1.6",
    "jest": "^29.7.0",
    "nock": "^13.5.0",
    "ts-jest": "^29.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0"
  }
}
